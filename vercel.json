{
  "buildCommand": "bash build.sh",
  "outputDirectory": "public_out",
  "rewrites": [
    { "source": "/aristo", "destination": "/aristo/index.html" },
    { "source": "/aristo/(.*)", "destination": "/aristo/$1" },
    { "source": "/asli", "destination": "/asli/index.html" },
    { "source": "/asli/(.*)", "destination": "/asli/$1" }
  ]
}
